{
  "_comment": "LeftPad ショートカット定義ファイル",
  "_note": "キー名は pyautogui の hotkey() に渡す文字列。複数キーは配列で指定する。",
  "_ref_pyautogui": "https://pyautogui.readthedocs.io/en/latest/keyboard.html#keyboard-keys",

  "===  操作  ===": "---",
  "元に戻す": ["ctrl", "z"],
  "やり直し": ["ctrl", "y"],
  "保存": ["ctrl", "s"],
  "選択解除": ["ctrl", "d"],

  "===  ツール  ===": "---",
  "ブラシ": ["b"],
  "消しゴム": ["e"],
  "塗りつぶし": ["g"],
  "スポイト": ["i"],
  "矩形選択": ["m"],
  "移動": ["v"],
  "ペン": ["p"],
  "テキスト": ["t"],
  "なげなわ": ["l"],

  "===  カラー  ===": "---",
  "前後景切替": ["x"],
  "白黒リセット": ["d"],

  "===  ブラシサイズ  ===": "---",
  "ブラシサイズアップ": ["]"],
  "ブラシサイズダウン": ["["],

  "===  ズーム  ===": "---",
  "拡大": ["ctrl", "+"],
  "縮小": ["ctrl", "-"],
  "全体表示": ["ctrl", "0"],
  "100%表示": ["ctrl", "1"],

  "===  キャンバス回転  ===": "---",
  "右回転": ["ctrl", "alt", "right"],
  "左回転": ["ctrl", "alt", "left"],
  "回転リセット": ["ctrl", "alt", "0"],
  "左右反転": ["ctrl", "shift", "h"],

  "===  表示  ===": "---",
  "全画面": ["tab"],

  "===  レイヤー  ===": "---",
  "レイヤー新規": ["ctrl", "shift", "n"],
  "レイヤー削除": ["delete"],
  "レイヤー結合": ["ctrl", "e"],
  "レイヤー複製": ["ctrl", "j"],
  "レイヤー上": ["ctrl", "]"],
  "レイヤー下": ["ctrl", "["]
}
